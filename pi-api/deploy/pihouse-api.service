[Unit]
Description=Pi House Audio Local API
After=network-online.target pipewire.service wireplumber.service

[Service]
WorkingDirectory=%h/pihouse/pi-api
Environment=PIHOUSE_CONFIG=%h/.config/pihouse-api/config.json
ExecStart=%h/pihouse/pi-api/.venv/bin/python -m uvicorn pihouse_api.app:app --host 0.0.0.0 --port 8765
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
